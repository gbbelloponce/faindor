{
  "name": "faindor",
  "packageManager": "bun@1.2.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "bun --filter '*' dev",
    "typecheck": "bun run --cwd apps/api build:types && bun run --cwd apps/web-ui typecheck",
    "lint": "bunx biome check --write ./apps/",
    "clean": "rm -rf node_modules/ bun.lock"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx,js,jsx,json}": "bunx biome check --write"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@tailwindcss/oxide"
  ]
}